{
    "name": "aigamewebsite",
    "version": "1.0.0",
    "scripts": {
        "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
        "dev:frontend": "vite",
        "dev:backend": "python3 src/backend/app.py",
        "build": "vite build",
        "preview": "vite preview",
        "test": "npm run test:unit && npm run test:e2e",
        "test:unit": "jest tests/unit",
        "test:unit:coverage": "jest tests/unit --coverage --watchAll=false",
        "test:e2e": "playwright test",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:debug": "playwright test --debug",
        "test:smoke": "playwright test tests/smoke",
        "test:games": "playwright test tests/games",
        "test:auth": "playwright test tests/auth",
        "test:api": "playwright test tests/api",
        "test:navigation": "playwright test tests/e2e",
        "test:performance": "playwright test tests/performance",
        "format": "prettier --write \"src/**/*.{ts,tsx,js,css,html}\" \"tests/**/*.js\" \"*.{js,ts,json,md}\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx,js,css,html}\" \"tests/**/*.js\" \"*.{js,ts,json,md}\"",
        "deps:check": "npm outdated",
        "deps:update": "npx npm-check-updates --upgrade --target minor && npm install"
    },
    "dependencies": {
        "@tanstack/react-query": "^5.64.2",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-router-dom": "^6.28.2",
        "zustand": "^5.0.3"
    },
    "devDependencies": {
        "@eslint/js": "^9.32.0",
        "@playwright/test": "^1.54.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^4.3.4",
        "autoprefixer": "^10.4.27",
        "concurrently": "^9.2.0",
        "daisyui": "^4.12.24",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jest": "^29.15.1",
        "jest": "^30.3.0",
        "npm-check-updates": "^17.1.18",
        "postcss": "^8.5.6",
        "prettier": "^3.6.2",
        "tailwindcss": "^3.4.17",
        "typescript": "^6.0.2",
        "vite": "^6.4.1"
    }
}
