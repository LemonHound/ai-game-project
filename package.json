{
    "name": "aigamewebsite",
    "version": "1.0.0",
    "scripts": {
        "dev": "concurrently \"npm run build-css:watch\" \"nodemon src/backend/server.js\"",
        "dev:full": "",
        "start": "npm run build-css && node src/backend/server.js",
        "start:full": "",
        "test": "npm run test:unit && npm run test:e2e",
        "test:unit": "jest tests/unit",
        "test:unit:coverage": "jest tests/unit --coverage --watchAll=false",
        "test:e2e": "playwright test",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:debug": "playwright test --debug",
        "test:smoke": "playwright test tests/smoke",
        "test:games": "playwright test tests/games",
        "test:auth": "playwright test tests/auth",
        "test:api": "playwright test tests/api",
        "test:navigation": "playwright test tests/e2e",
        "test:performance": "playwright test tests/performance",
        "format": "prettier --write \"src/**/*.{js,css,html}\" \"tests/**/*.js\" \"*.{js,json,md}\"",
        "format:check": "prettier --check \"src/**/*.{js,css,html}\" \"tests/**/*.js\" \"*.{js,json,md}\"",
        "deps:check": "npm outdated",
        "deps:update": "npx npm-check-updates --upgrade --target minor && npm install",
        "deps:update:major": "npx npm-check-updates --upgrade && npm install",
        "build-css": "tailwindcss -i ./src/frontend/public/css/input.css -o ./src/frontend/public/css/output.css --minify",
        "build-css:watch": "tailwindcss -i ./src/frontend/public/css/input.css -o ./src/frontend/public/css/output.css --watch",
        "dev:python": "C:/Users/seiwe/miniconda3/envs/AIGameWebsite/python.exe src/backend/app.py"
    },
    "dependencies": {
        "@parcel/watcher": "^2.5.1",
        "@tailwindcss/postcss": "^4.1.11",
        "autoprefixer": "^10.4.21",
        "bcrypt": "^6.0.0",
        "concurrently": "^9.2.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "csurf": "^1.11.0",
        "dotenv": "^17.2.1",
        "ejs": "^3.1.10",
        "express": "^5.1.0",
        "express-session": "^1.18.2",
        "google-auth-library": "^10.2.1",
        "helmet": "^8.1.0",
        "morgan": "^1.10.1",
        "path-to-regexp": "8.2.0",
        "pg": "^8.16.3",
        "postcss": "^8.5.6",
        "postcss-cli": "^11.0.1",
        "tailwindcss": "^3.4.17",
        "uuid": "^11.1.0"
    },
    "devDependencies": {
        "@playwright/test": "^1.54.2",
        "daisyui": "^4.12.24",
        "@eslint/js": "^9.32.0",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jest": "^28.14.0",
        "jest": "^29.7.0",
        "nodemon": "^3.1.10",
        "npm-check-updates": "^17.1.18",
        "prettier": "^3.6.2",
        "supertest": "^6.3.4"
    }
}
