<div class="h-full overflow-y-auto p-4 lg:p-6">
    <!-- Hero Section -->
    <section class="hero min-h-96 bg-gradient-to-br from-primary to-secondary rounded-lg mb-8">
        <div class="hero-content text-center text-primary-content">
            <div class="max-w-md">
                <h1 class="mb-5 text-5xl font-bold">Welcome to AI Game Hub</h1>
                <p class="mb-5">
                    Experience the future of gaming with AI-powered opponents that adapt to your play style.
                    Challenge yourself with classic games enhanced by intelligent artificial intelligence.
                </p>
                <a href="/games" class="btn btn-accent btn-lg">Get Started</a>
            </div>
        </div>
    </section>

    <!-- Featured Games Section -->
    <section class="mb-12">
        <div class="text-center mb-8">
            <h2 class="text-3xl font-bold mb-4">🌟 Featured Games</h2>
            <p class="text-lg opacity-70 max-w-2xl mx-auto">
                Jump right into our most popular AI-powered games
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <% featuredGames.forEach(game => { %>
                <div class="card bg-base-200 shadow-xl hover:shadow-2xl transition-all duration-300 card-game-link">
                    <figure class="px-6 pt-6">
                        <div class="w-full h-24 bg-gradient-to-br from-accent to-secondary rounded-lg flex items-center justify-center">
                            <span class="text-4xl"><%= game.icon %></span>
                        </div>
                    </figure>
                    <div class="card-body text-center">
                        <h3 class="card-title justify-center"><%= game.name %></h3>
                        <p class="opacity-70 text-sm"><%= game.description %></p>
                        <div class="card-actions justify-center mt-4">
                            <a href="/game/<%= game.id %>" class="btn btn-primary">Play Now</a>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>

        <div class="text-center mt-8">
            <a href="/games" class="btn btn-outline">View All Games</a>
        </div>
    </section>

    <!-- Features Section -->
    <section class="mb-12">
        <div class="text-center mb-8">
            <h2 class="text-3xl font-bold mb-4">🚀 Why Choose AI Game Hub?</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <div class="card bg-base-200 shadow-lg">
                <div class="card-body text-center">
                    <div class="text-4xl mb-4">🧠</div>
                    <h3 class="card-title justify-center text-lg">Smart AI</h3>
                    <p class="text-sm opacity-70">Our AI adapts to your playing style and provides challenging gameplay</p>
                </div>
            </div>

            <div class="card bg-base-200 shadow-lg">
                <div class="card-body text-center">
                    <div class="text-4xl mb-4">🎮</div>
                    <h3 class="card-title justify-center text-lg">Classic Games</h3>
                    <p class="text-sm opacity-70">Enjoy timeless games enhanced with modern AI technology</p>
                </div>
            </div>

            <div class="card bg-base-200 shadow-lg">
                <div class="card-body text-center">
                    <div class="text-4xl mb-4">📱</div>
                    <h3 class="card-title justify-center text-lg">Responsive Design</h3>
                    <p class="text-sm opacity-70">Play seamlessly on desktop, tablet, or mobile devices</p>
                </div>
            </div>

            <div class="card bg-base-200 shadow-lg">
                <div class="card-body text-center">
                    <div class="text-4xl mb-4">🏆</div>
                    <h3 class="card-title justify-center text-lg">Track Progress</h3>
                    <p class="text-sm opacity-70">Monitor your performance and improve your skills over time</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="mb-8">
        <div class="stats stats-horizontal shadow-lg bg-base-200 w-full">
            <div class="stat">
                <div class="stat-figure text-primary">
                    <span class="text-3xl">🎯</span>
                </div>
                <div class="stat-title">Games Available</div>
                <div class="stat-value text-primary"><%= featuredGames.length + 3 %></div>
                <div class="stat-desc">And more coming soon!</div>
            </div>

            <div class="stat">
                <div class="stat-figure text-secondary">
                    <span class="text-3xl">🤖</span>
                </div>
                <div class="stat-title">AI Powered</div>
                <div class="stat-value text-secondary">100%</div>
                <div class="stat-desc">Intelligent gameplay</div>
            </div>

            <div class="stat">
                <div class="stat-figure text-accent">
                    <span class="text-3xl">⚡</span>
                </div>
                <div class="stat-title">Performance</div>
                <div class="stat-value text-accent">Fast</div>
                <div class="stat-desc">Optimized experience</div>
            </div>
        </div>
    </section>
</div>