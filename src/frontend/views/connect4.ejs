<!-- Game Header -->
<div class="mb-6">
    <div class="breadcrumbs text-sm mb-4">
        <ul>
            <li><a href="/" class="link">Home</a></li>
            <li><a href="/games" class="link">Games</a></li>
            <li class="opacity-70">Connect 4</li>
        </ul>
    </div>

    <div class="flex flex-col lg:flex-row lg:items-center gap-4 mb-6">
        <div class="flex items-center gap-4">
            <div class="w-16 h-16 bg-gradient-to-br from-accent to-secondary rounded-xl flex items-center justify-center">
                <span class="text-3xl">🔴</span>
            </div>
            <div>
                <h1 class="text-3xl font-bold">Connect 4</h1>
                <p class="text-base-content opacity-70">Connect four pieces in a row to win!</p>
            </div>
        </div>

        <div class="flex gap-2 lg:ml-auto">
            <button class="btn btn-primary" onclick="startGame()">
                <span class="mr-2">🎮</span>
                New Game
            </button>
            <button class="btn btn-outline" onclick="restartGame()">
                <span class="mr-2">🔄</span>
                Restart
            </button>
            <button class="btn btn-outline" onclick="toggleStarter()">
                <span class="mr-2">🔀</span>
                Switch Starter
            </button>
            <button class="btn btn-outline" onclick="getHint()">
                <span class="mr-2">💡</span>
                Hint
            </button>
            <button class="btn btn-outline" onclick="openModal('rules-modal')">
                <span class="mr-2">❓</span>
                Rules
            </button>
        </div>
    </div>
</div>

<!-- Game Stats -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
    <div class="stat bg-base-200 rounded-lg">
        <div class="stat-title">Games Played</div>
        <div class="stat-value text-primary"><%= gameStats.gamesPlayed %></div>
        <div class="stat-desc">Total matches</div>
    </div>
    <div class="stat bg-base-200 rounded-lg">
        <div class="stat-title">Win Rate</div>
        <div class="stat-value text-secondary"><%= gameStats.winRate %>%</div>
        <div class="stat-desc">Against AI</div>
    </div>
    <div class="stat bg-base-200 rounded-lg">
        <div class="stat-title">Best Streak</div>
        <div class="stat-value text-accent"><%= gameStats.bestStreak %></div>
        <div class="stat-desc">Consecutive wins</div>
    </div>
    <div class="stat bg-base-200 rounded-lg">
        <div class="stat-title">AI Level</div>
        <div class="stat-value text-success"><%= gameStats.aiLevel %></div>
        <div class="stat-desc">Adaptive difficulty</div>
    </div>
</div>

<!-- Game Board Container -->
<div class="flex flex-col lg:flex-row gap-6">
    <!-- Game Board -->
    <div class="flex-1">
        <div class="card bg-base-200 shadow-xl">
            <div class="card-body">
                <!-- Game Status -->
                <div class="flex items-center justify-between mb-4">
                    <div>
                        <h2 id="game-status" class="text-lg font-semibold mb-2 text-primary">
                            Your turn! Choose a column to drop your red piece.
                        </h2>
                        <!-- Player indicators -->
                        <div class="flex items-center gap-6">
                            <div class="flex items-center gap-2">
                                <div class="w-6 h-6 bg-error rounded-full"></div>
                                <span>You (Red)</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <div class="w-6 h-6 bg-warning rounded-full"></div>
                                <span>AI (Yellow)</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Connect 4 Board -->
                <div id="game-board" class="mb-4">
                    <!-- Game board will be populated by JavaScript -->
                </div>

                <!-- Game Controls -->
                <div class="flex justify-center gap-2">
                    <button class="btn btn-outline btn-sm" onclick="restartGame()">
                        <span class="mr-1">🔄</span>
                        Reset
                    </button>
                    <button class="btn btn-outline btn-sm" onclick="getHint()">
                        <span class="mr-1">💡</span>
                        Hint
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Game Info Panel -->
    <div class="lg:w-80">
        <!-- AI Thoughts -->
        <div class="card bg-base-200 shadow-lg mb-4">
            <div class="card-body">
                <h3 class="card-title text-lg">🤖 AI Thoughts</h3>
                <div class="text-sm opacity-70" id="ai-thoughts">
                    Ready to play Connect 4! Drop your red piece in any column.
                </div>
            </div>
        </div>

        <!-- Move History -->
        <div class="card bg-base-200 shadow-lg mb-4">
            <div class="card-body">
                <h3 class="card-title text-lg">📋 Move History</h3>
                <div class="overflow-y-auto max-h-40" id="move-history">
                    <!-- Move history will be populated by JavaScript -->
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Rules Modal -->
<div id="rules-modal" class="modal">
    <div class="modal-box">
        <h3 class="font-bold text-lg mb-4">🔴 Connect 4 Rules</h3>
        <div class="space-y-3 text-sm">
            <p><strong>Objective:</strong> Be the first to connect four of your pieces in a row - horizontally, vertically, or diagonally.</p>

            <p><strong>How to Play:</strong></p>
            <ul class="list-disc list-inside space-y-1 ml-4">
                <li>You are red pieces, AI is yellow pieces</li>
                <li>Click the ↓ button above any column to drop your piece</li>
                <li>Pieces fall to the lowest available spot in that column</li>
                <li>First to get 4 in a row wins!</li>
            </ul>

            <p><strong>Strategy Tips:</strong></p>
            <ul class="list-disc list-inside space-y-1 ml-4">
                <li><strong>Control the center:</strong> Center columns offer more winning opportunities</li>
                <li><strong>Think vertically:</strong> Watch for vertical connections as well as horizontal</li>
                <li><strong>Block and build:</strong> Always block opponent's three-in-a-row while building your own</li>
                <li><strong>Create threats:</strong> Set up multiple ways to win on your next turn</li>
                <li><strong>Watch diagonals:</strong> Diagonal wins are often overlooked but powerful</li>
            </ul>
        </div>
        <div class="modal-action">
            <button class="btn" onclick="closeModal('rules-modal')">Got it!</button>
        </div>
    </div>
    <div class="modal-backdrop" onclick="closeModal('rules-modal')"></div>
</div>