<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title }}</title>
    <link rel="stylesheet" href="/static/css/output.css" />
</head>
<body class="min-h-screen bg-base-200">
{% include 'partials/navbar.html' %}

<div class="container mx-auto px-4 py-8 max-w-6xl">
    <h1 class="text-4xl font-bold mb-8">Profile</h1>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-1">
            <div class="card bg-base-100 shadow-xl">
                <div class="card-body items-center text-center">
                    <div class="avatar placeholder mb-4">
                        <div class="bg-neutral text-neutral-content rounded-full w-24">
                            <img id="profile-avatar" class="hidden rounded-full" alt="Profile avatar" />
                            <span id="profile-initial" class="text-3xl">U</span>
                        </div>
                    </div>
                    <h2 id="profile-display-name" class="card-title text-2xl">Display Name</h2>
                    <p id="profile-username" class="text-base-content/70">@username</p>
                    <div class="divider"></div>
                    <div class="w-full text-left space-y-2">
                        <div id="profile-email-section">
                            <p class="text-sm text-base-content/60">Email</p>
                            <p id="profile-email" class="font-medium">user@example.com</p>
                        </div>
                        <div class="pt-2" id="profile-password-section">
                            <button class="btn btn-outline btn-sm w-full" onclick="openChangePasswordModal()">
                                Change Password
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card bg-base-100 shadow-xl mt-6">
                <div class="card-body">
                    <h3 class="card-title text-lg">Account Info</h3>
                    <div class="space-y-3">
                        <div>
                            <p class="text-sm text-base-content/60">Member Since</p>
                            <p id="profile-member-since" class="font-medium">January 15, 2024</p>
                        </div>
                        <div>
                            <p class="text-sm text-base-content/60">Last Login</p>
                            <p id="profile-last-login" class="font-medium">2 hours ago</p>
                        </div>
                        <div>
                            <p class="text-sm text-base-content/60">Account Type</p>
                            <p id="profile-account-type" class="font-medium">Standard</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="lg:col-span-2">
            <div class="card bg-base-100 shadow-xl">
                <div class="card-body">
                    <h3 class="card-title text-2xl mb-4">Gaming Statistics</h3>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                        <div class="stat bg-base-200 rounded-lg">
                            <div class="stat-title">Total Games Played</div>
                            <div id="stat-total-games" class="stat-value text-primary">847</div>
                            <div class="stat-desc">Across all game types</div>
                        </div>
                        <div class="stat bg-base-200 rounded-lg">
                            <div class="stat-title">Win Rate</div>
                            <div id="stat-win-rate" class="stat-value text-secondary">68%</div>
                            <div class="stat-desc">Overall performance</div>
                        </div>
                    </div>

                    <div class="divider">AI Training Contributions</div>

                    <div class="space-y-4">
                        <div class="flex justify-between items-center p-4 bg-base-200 rounded-lg">
                            <div>
                                <p class="font-semibold">Chess AI</p>
                                <p class="text-sm text-base-content/60">Time contributed</p>
                            </div>
                            <div class="text-right">
                                <p id="training-chess-time" class="text-lg font-bold">12h 34m</p>
                                <p id="training-chess-games" class="text-sm text-base-content/60">245 games</p>
                            </div>
                        </div>

                        <div class="flex justify-between items-center p-4 bg-base-200 rounded-lg">
                            <div>
                                <p class="font-semibold">Tic-Tac-Toe AI</p>
                                <p class="text-sm text-base-content/60">Time contributed</p>
                            </div>
                            <div class="text-right">
                                <p id="training-tictactoe-time" class="text-lg font-bold">3h 18m</p>
                                <p id="training-tictactoe-games" class="text-sm text-base-content/60">156 games</p>
                            </div>
                        </div>

                        <div class="flex justify-between items-center p-4 bg-base-200 rounded-lg">
                            <div>
                                <p class="font-semibold">Connect Four AI</p>
                                <p class="text-sm text-base-content/60">Time contributed</p>
                            </div>
                            <div class="text-right">
                                <p id="training-connect4-time" class="text-lg font-bold">8h 52m</p>
                                <p id="training-connect4-games" class="text-sm text-base-content/60">189 games</p>
                            </div>
                        </div>

                        <div class="flex justify-between items-center p-4 bg-base-200 rounded-lg">
                            <div>
                                <p class="font-semibold">Checkers AI</p>
                                <p class="text-sm text-base-content/60">Time contributed</p>
                            </div>
                            <div class="text-right">
                                <p id="training-checkers-time" class="text-lg font-bold">6h 10m</p>
                                <p id="training-checkers-games" class="text-sm text-base-content/60">257 games</p>
                            </div>
                        </div>
                    </div>

                    <div class="divider">Total Contribution</div>

                    <div class="stat bg-primary text-primary-content rounded-lg">
                        <div class="stat-title text-primary-content/80">Total Training Time</div>
                        <div id="stat-total-training-time" class="stat-value">30h 54m</div>
                        <div class="stat-desc text-primary-content/80">Thank you for improving our AI</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% include 'partials/footer.html' %}

{% include 'partials/auth-modal.html' %}

<dialog id="change-password-modal" class="modal">
    <div class="modal-box">
        <h3 class="font-bold text-lg mb-4">Change Password</h3>
        <form id="change-password-form" class="space-y-4">
            <div class="form-control">
                <label class="label">
                    <span class="label-text">Current Password</span>
                </label>
                <input
                        type="password"
                        name="currentPassword"
                        class="input input-bordered"
                        required
                />
            </div>
            <div class="form-control">
                <label class="label">
                    <span class="label-text">New Password</span>
                </label>
                <input
                        type="password"
                        name="newPassword"
                        class="input input-bordered"
                        required
                />
            </div>
            <div class="form-control">
                <label class="label">
                    <span class="label-text">Confirm New Password</span>
                </label>
                <input
                        type="password"
                        name="confirmPassword"
                        class="input input-bordered"
                        required
                />
            </div>
            <div id="password-error" class="alert alert-error hidden">
                <span>Error message</span>
            </div>
            <div class="modal-action">
                <button type="button" class="btn" onclick="closeChangePasswordModal()">Cancel</button>
                <button type="submit" class="btn btn-primary">Update Password</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button>close</button>
    </form>
</dialog>

<script>
    let currentUser = null;

    function deleteCookie(name) {
        document.cookie = name + '=; Path=/; Expires=Thu, 01 Jan 1970 00:00:01 GMT;';
        document.cookie = name + '=; Path=/; Domain=localhost; Expires=Thu, 01 Jan 1970 00:00:01 GMT;';
    }

    async function checkAuthStatus() {
        try {
            const response = await fetch('/api/auth/me', {
                credentials: 'include',
                headers: { Accept: 'application/json' },
                cache: 'no-cache',
            });

            if (response.ok) {
                currentUser = await response.json();
                updateUIForAuthenticatedUser(currentUser);
            } else {
                window.location.href = '/';
            }
        } catch (error) {
            console.error('Auth check failed:', error);
            window.location.href = '/';
        }
    }

    function updateUIForAuthenticatedUser(user) {
        document.getElementById('auth-logged-out').classList.add('hidden');
        document.getElementById('auth-logged-in').classList.remove('hidden');

        document.getElementById('user-display-name').textContent = user.displayName || user.username;
        document.getElementById('profile-display-name').textContent = user.displayName || user.username;
        document.getElementById('profile-username').textContent = '@' + user.username;

        const initial = (user.displayName || user.username || 'U')[0].toUpperCase();
        document.getElementById('user-initial').textContent = initial;
        document.getElementById('profile-initial').textContent = initial;

        if (user.profilePicture) {
            document.getElementById('user-avatar').src = user.profilePicture;
            document.getElementById('user-avatar').classList.remove('hidden');
            document.getElementById('user-initial').classList.add('hidden');

            document.getElementById('profile-avatar').src = user.profilePicture;
            document.getElementById('profile-avatar').classList.remove('hidden');
            document.getElementById('profile-initial').classList.add('hidden');
        }

        if (user.authProvider === 'google') {
            document.getElementById('profile-email-section').classList.add('hidden');
            document.getElementById('profile-password-section').classList.add('hidden');
            document.getElementById('profile-account-type').textContent = 'Google Account';
        } else {
            document.getElementById('profile-email').textContent = user.email || 'Not provided';
            document.getElementById('profile-account-type').textContent = 'Standard Account';
        }
    }

    function openLoginModal() {
        document.getElementById('login-modal').showModal();
    }

    function openChangePasswordModal() {
        document.getElementById('change-password-modal').showModal();
    }

    function closeChangePasswordModal() {
        document.getElementById('change-password-modal').close();
        document.getElementById('change-password-form').reset();
        document.getElementById('password-error').classList.add('hidden');
    }

    document.getElementById('change-password-form').addEventListener('submit', async e => {
        e.preventDefault();
        const errorDiv = document.getElementById('password-error');
        errorDiv.classList.add('hidden');

        const formData = new FormData(e.target);
        const newPassword = formData.get('newPassword');
        const confirmPassword = formData.get('confirmPassword');

        if (newPassword !== confirmPassword) {
            errorDiv.querySelector('span').textContent = 'New passwords do not match';
            errorDiv.classList.remove('hidden');
            return;
        }

        const data = {
            currentPassword: formData.get('currentPassword'),
            newPassword: newPassword,
        };

        try {
            const response = await fetch('/api/auth/change-password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify(data),
            });

            const result = await response.json();

            if (response.ok) {
                closeChangePasswordModal();
                alert('Password changed successfully');
            } else {
                errorDiv.querySelector('span').textContent = result.detail || 'Failed to change password';
                errorDiv.classList.remove('hidden');
            }
        } catch (error) {
            errorDiv.querySelector('span').textContent = 'Network error. Please try again.';
            errorDiv.classList.remove('hidden');
        }
    });

    document.getElementById('logout-btn').addEventListener('click', async () => {
        try {
            await fetch('/api/auth/logout', {
                method: 'POST',
                credentials: 'include',
                headers: { 'Content-Type': 'application/json' },
            });

            deleteCookie('sessionId');
            window.location.href = '/';
        } catch (error) {
            console.error('Logout failed:', error);
        }
    });

    checkAuthStatus();
</script>
</body>
</html>