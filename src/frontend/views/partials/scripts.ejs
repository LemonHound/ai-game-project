<!-- Enhanced scripts with authentication support -->

<!-- Google Identity Services configuration -->
<script>
    // Set Google Client ID from environment (you'll need to pass this from your server)
    window.GOOGLE_CLIENT_ID = '<%= process.env.GOOGLE_CLIENT_ID || "YOUR_GOOGLE_CLIENT_ID" %>';
</script>

<!-- Include the authentication manager -->
<script src="/js/auth-manager.js"></script>

<!-- Only include page-specific scripts -->
<% if (typeof pageScripts !== 'undefined' && pageScripts.length > 0) { %>
    <% pageScripts.forEach(script => { %>
        <script src="/js/<%= script %>"></script>
    <% }); %>
<% } %>

<!-- Basic utility functions -->
<script>
    // Simple utility functions - no HTML rendering
    function closeModal(modalId) {
        const modal = document.getElementById(modalId);
        if (modal) {
            modal.classList.remove('modal-open');
        }
    }

    function openModal(modalId) {
        const modal = document.getElementById(modalId);
        if (modal) {
            modal.classList.add('modal-open');
        }
    }

    function toggleMobileSidebar() {
        const sidebar = document.getElementById('mobile-sidebar');
        if (sidebar) {
            sidebar.classList.toggle('hidden');
        }
    }
</script>