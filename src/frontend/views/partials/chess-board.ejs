<!-- Desktop Layout (Hidden on mobile) -->
<div class="hidden lg:flex justify-center items-start gap-6 max-w-7xl mx-auto">
    <!-- Left Column: Game Status -->
    <div class="w-full h-full justify-center items-center text-center content-center">
        <div class="card bg-base-200 shadow-sm p-4 text-center content-center items-center justify-center">
            <h2 id="chess-game-status" class="text-lg font-semibold text-primary mb-3">
                <span id="chess-game-status-text"><!-- Status messages appear here --></span>
            </h2>

            <!-- Turn Indicator -->
            <div class="text-center mb-3">
                <div id="turn-indicator" class="badge badge-lg badge-primary">
                    <span id="current-player-text"><!-- Turn info appears here --></span>
                </div>
            </div>

            <!-- Reset Game Button -->
            <div class="space-y-2 text-center align-bottom">
                <button class="btn btn-error btn-sm w-48" onclick="chessGame.resetGame()">
                    <span class="text-sm">🔄</span>
                    Reset Game
                </button>
            </div>
        </div>
    </div>

    <!-- Center Column: Chess Board (Fixed Size) -->
    <div class="flex-shrink-0 relative">
        <!-- Chess Board -->
        <div class="bg-base-300 p-4 rounded-xl shadow-xl">
            <div id="chess-board" class="grid grid-cols-8 gap-0 w-96 h-96 mx-auto border-2 border-base-content rounded-lg overflow-hidden relative">
                <!-- Board squares will be generated by JavaScript -->
            </div>

            <!-- Color Selection Overlay -->
            <div class="color-selection-overlay absolute inset-4 flex items-center justify-center bg-black bg-opacity-60 rounded-lg">
                <div class="text-center space-y-4">
                    <h3 class="text-white text-xl font-bold mb-4">Choose Your Color</h3>
                    <button class="btn btn-primary btn-lg border-2 m-2" onclick="startGame(true)">
                        Play as White
                    </button>
                    <button class="btn btn-secondary btn-lg border-2 m-2" onclick="startGame(false)">
                        Play as Black
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Game Controls -->
    <div class="w-48 flex-shrink-0">
        <div class="card bg-base-200 shadow-sm p-4">
            <h3 class="font-semibold mb-3">Board Controls</h3>

            <div class="space-y-2">
                <button id="flip-board-btn" class="btn btn-outline btn-sm w-full" onclick="chessGame.flipBoard()">
                    <span class="text-sm">🔄</span>
                    Flip Board
                </button>
            </div>

            <!-- Captured Pieces -->
            <div class="divider my-4"></div>
            <div class="space-y-3">
                <div>
                    <h4 class="text-xs font-bold mb-1">Captured by White:</h4>
                    <div id="captured-by-white" class="flex flex-wrap gap-1 min-h-[30px] p-2 bg-base-100 rounded text-sm">
                        <!-- Captured pieces will appear here -->
                    </div>
                </div>
                <div>
                    <h4 class="text-xs font-bold mb-1">Captured by Black:</h4>
                    <div id="captured-by-black" class="flex flex-wrap gap-1 min-h-[30px] p-2 bg-base-100 rounded text-sm">
                        <!-- Captured pieces will appear here -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Mobile Layout (Stack vertically on small screens) -->
<div class="md:hidden">
    <div class="space-y-4">
        <!-- Mobile Status and Controls -->
        <div class="card bg-base-200 shadow-sm p-4">
            <div class="flex justify-between items-center mb-3">
                <div id="mobile-chess-game-status" class="badge badge-lg badge-primary">
                    <span id="mobile-game-status-text"><!-- Status message appears here --></span>
                </div>
                <div id="mobile-turn-indicator" class="badge badge-lg badge-primary">
                    <span id="mobile-current-player-text"><!-- Turn info appears here --></span>
                </div>
            </div>
            <div class="flex gap-2 mb-3">
                <button class="btn btn-error btn-sm flex-1" onclick="chessGame.resetGame()">
                    🔄 Reset
                </button>
                <button class="btn btn-outline btn-sm" onclick="chessGame.flipBoard()">
                    🔄
                </button>
            </div>
        </div>

        <!-- Mobile Board -->
        <div class="flex justify-center relative">
            <div class="bg-base-300 p-3 rounded-xl shadow-xl">
                <div id="mobile-chess-board" class="grid grid-cols-8 gap-0 w-80 h-80 border-2 border-base-content rounded-lg overflow-hidden relative">
                    <!-- Mobile board squares will be populated by JavaScript -->
                </div>

                <!-- Mobile Color Selection Overlay -->
                <div class="color-selection-overlay absolute inset-3 flex items-center justify-center bg-black bg-opacity-60 rounded-lg">
                    <div class="text-center space-y-4">
                        <h3 class="text-white text-lg font-bold mb-3">Choose Your Color</h3>
                        <div class="space-y-2">
                            <button class="btn btn-primary btn-md w-40" onclick="startGame(true)">
                                ⚪ White
                            </button>
                            <button class="btn btn-outline btn-md w-40 text-white border-white hover:bg-white hover:text-black" onclick="startGame(false)">
                                ⚫ Black
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Mobile Captured Pieces -->
        <div class="flex justify-between gap-4">
            <div class="flex-1">
                <h4 class="text-xs font-bold mb-1">White Captured:</h4>
                <div id="mobile-captured-by-white" class="flex flex-wrap gap-1 min-h-[25px] p-2 bg-base-200 rounded text-sm">
                </div>
            </div>
            <div class="flex-1">
                <h4 class="text-xs font-bold mb-1">Black Captured:</h4>
                <div id="mobile-captured-by-black" class="flex flex-wrap gap-1 min-h-[25px] p-2 bg-base-200 rounded text-sm">
                </div>
            </div>
        </div>
    </div>
</div>

<script src="/js/basic-chess-ai.js"></script>