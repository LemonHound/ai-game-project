<!-- Chess Game Board -->
<div id="game-board-container" class="max-w-2xl mx-auto">
    <!-- Player Turn Indicator -->
    <div class="text-center mb-4">
        <div id="turn-indicator" class="badge badge-lg">
            <span id="current-player-text">White's Turn</span>
        </div>
    </div>

    <!-- Game Controls -->
    <div class="flex justify-center gap-2 mb-4">
        <button id="flip-board-btn" class="btn btn-outline btn-sm" onclick="chessGame.flipBoard()">
            <span class="text-sm">🔄</span>
            Flip Board
        </button>
        <button id="play-as-white-btn" class="btn btn-primary btn-sm" onclick="startGame(true)">
            <span class="text-sm">⚪</span>
            Play as White
        </button>
        <button id="play-as-black-btn" class="btn btn-secondary btn-sm" onclick="startGame(false)">
            <span class="text-sm">⚫</span>
            Play as Black
        </button>
    </div>

    <!-- Chess Board -->
    <div class="bg-base-300 p-4 rounded-xl shadow-xl">
        <div id="chess-board" class="grid grid-cols-8 gap-0 max-w-md mx-auto border-2 border-base-content">
            <!-- Board squares will be generated by JavaScript -->
        </div>
    </div>

    <!-- Captured Pieces -->
    <div class="flex justify-between mt-4 px-4">
        <div>
            <h4 class="text-sm font-bold mb-2">Captured by White:</h4>
            <div id="captured-by-white" class="flex flex-wrap gap-1 min-h-[30px] p-2 bg-base-200 rounded">
                <!-- Captured pieces will appear here -->
            </div>
        </div>
        <div>
            <h4 class="text-sm font-bold mb-2">Captured by Black:</h4>
            <div id="captured-by-black" class="flex flex-wrap gap-1 min-h-[30px] p-2 bg-base-200 rounded">
                <!-- Captured pieces will appear here -->
            </div>
        </div>
    </div>
</div>

<!-- Game Status -->
<div class="text-center mt-6">
    <div id="game-status" class="text-lg font-semibold mb-4">
        Choose your color to start playing!
    </div>
    <div id="game-info" class="text-sm opacity-70">
        Click a piece to see valid moves. This is a practice board - no AI opponent.
    </div>
</div>