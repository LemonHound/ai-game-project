<!-- 3-Column Layout to keep board centered -->
<div class="flex items-start gap-4 justify-between">
    <!-- Left Column: Game Status and Player Info -->
    <div class="w-48 flex-shrink-0">
        <div class="card bg-base-200 shadow-sm p-4">
            <h2 id="game-status" class="text-lg font-semibold mb-3 text-primary h-full content-center">
                Your turn! Click on any line to start.
            </h2>

            <!-- Player indicators -->
            <div class="space-y-3">
                <div class="flex items-center gap-2">
                    <div class="w-4 h-4 bg-primary rounded"></div>
                    <span class="text-sm">You</span>
                </div>
                <div class="flex items-center gap-2">
                    <div class="w-4 h-4 bg-secondary rounded"></div>
                    <span class="text-sm">AI</span>
                </div>
            </div>

            <!-- Score Display -->
            <div class="divider my-4"></div>
            <div class="space-y-2">
                <div class="flex justify-between text-sm">
                    <span>You:</span>
                    <span id="player-score" class="font-bold text-primary">0</span>
                </div>
                <div class="flex justify-between text-sm">
                    <span>AI:</span>
                    <span id="ai-score" class="font-bold text-secondary">0</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Center Column: Game Board (Fixed Size) -->
    <div class="flex-shrink-0">
        <div id="game-board">
            <!-- Game board will be populated by JavaScript -->
        </div>
    </div>

    <!-- Right Column: Game Controls -->
    <div class="w-48 flex-shrink-0">
        <div class="card bg-base-200 shadow-sm p-4">
            <h3 class="font-semibold mb-3">Game Controls</h3>

            <div class="space-y-2">
                <button class="btn btn-outline btn-sm w-full" onclick="restartGame()">
                    <span class="mr-1">🔄</span>
                    Reset Game
                </button>
                <button class="btn btn-outline btn-sm w-full" onclick="getHint()">
                    <span class="mr-1">💡</span>
                    Get Hint
                </button>
            </div>

            <!-- Game Tips -->
            <div class="divider my-4"></div>
            <div class="text-xs opacity-70">
                <p class="mb-2"><strong>Goal:</strong> Complete more boxes than AI</p>
                <p class="mb-2"><strong>Tip:</strong> Avoid giving away boxes</p>
                <p><strong>Strategy:</strong> Control the chains</p>
            </div>
        </div>
    </div>
</div>

<!-- Mobile Layout (Stack vertically on small screens) -->
<div class="lg:hidden">
    <div class="space-y-4">
        <!-- Mobile Status -->
        <div class="card bg-base-200 shadow-sm p-4">
            <div class="flex justify-between items-center mb-2">
                <h2 id="mobile-game-status" class="text-lg font-semibold text-primary">
                    Your turn!
                </h2>
                <div class="flex gap-4 text-sm">
                    <span>You: <span id="mobile-player-score" class="font-bold text-primary">0</span></span>
                    <span>AI: <span id="mobile-ai-score" class="font-bold text-secondary">0</span></span>
                </div>
            </div>

            <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <div class="flex items-center gap-1">
                        <div class="w-3 h-3 bg-primary rounded"></div>
                        <span class="text-xs">You</span>
                    </div>
                    <div class="flex items-center gap-1">
                        <div class="w-3 h-3 bg-secondary rounded"></div>
                        <span class="text-xs">AI</span>
                    </div>
                </div>

                <div class="flex gap-1">
                    <button class="btn btn-outline btn-xs" onclick="restartGame()">
                        🔄
                    </button>
                    <button class="btn btn-outline btn-xs" onclick="getHint()">
                        💡
                    </button>
                </div>
            </div>
        </div>

        <!-- Mobile Board -->
        <div class="flex justify-center">
            <div id="mobile-game-board">
                <!-- Mobile game board will be populated by JavaScript -->
            </div>
        </div>
    </div>
</div>