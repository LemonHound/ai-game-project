<div class="flex flex-col items-center gap-4">
    <!-- Mouse tracking area that extends beyond the canvas -->
    <div id="pong-container" class="relative" style="width: 900px; height: 500px; cursor: crosshair;">
        <!-- Game Canvas centered within the container -->
        <canvas id="game-board" width="800" height="400"
                class="border-2 border-gray-400 bg-black absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2"></canvas>
    </div>

    <!-- Game Status -->
    <div id="game-status" class="text-center text-lg font-bold">
        <div id="score-display" class="text-2xl mb-2">0 - 0</div>
        <div id="status-text" class="text-base">Click on left or right side to start playing!</div>
    </div>
</div>