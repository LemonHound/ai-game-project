<div class="h-full overflow-hidden flex flex-col p-4 lg:p-6">
    <!-- Breadcrumbs - Fixed at top -->
    <div class="breadcrumbs text-sm mb-4 flex-shrink-0">
        <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/games">Games</a></li>
            <li class="text-primary font-semibold"><%= currentGame.name %></li>
        </ul>
    </div>

    <!-- Game Header - Fixed -->
    <div class="flex-shrink-0 mb-6">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
                <div class="w-16 h-16 bg-gradient-to-br from-accent to-secondary rounded-lg flex items-center justify-center">
                    <span class="text-3xl"><%= currentGame.icon %></span>
                </div>
                <div>
                    <h1 class="text-3xl font-bold"><%= currentGame.name %></h1>
                    <p class="opacity-70 text-sm"><%= currentGame.description %></p>
                </div>
            </div>

            <!-- Game Controls -->
            <div class="flex gap-2">
                <button class="btn btn-outline btn-sm" onclick="openModal('rules-modal')">
                    📋 Rules
                </button>
                <% if (currentGame.id !== 'chess') { %>
                    <button class="btn btn-secondary btn-sm" onclick="restartGame()" data-testid="restart-btn">
                        🔄 Restart
                    </button>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Game Content Area - Flexible -->
    <div class="flex-1 overflow-hidden flex flex-col lg:flex-row gap-6">
        <!-- Game Board Container -->
        <div class="flex-1 overflow-hidden flex flex-col">
            <div class="card bg-base-200 shadow-xl h-full">
                <div class="card-body h-full flex flex-col">
                    <h2 class="card-title mb-4 flex-shrink-0">Game Board</h2>

                    <!-- Game Board - Takes remaining space -->
                    <div class="flex-1 flex items-center justify-center overflow-hidden">
                        <!-- Game-specific content will be inserted here -->
                        <% if (currentGame.id === 'tic-tac-toe') { %>
                            <!-- Tic Tac Toe Board -->
                            <%- include('partials/tic-tac-toe-board') %>
                        <% } else if (currentGame.id === 'chess') { %>
                            <!-- Chess Board -->
                            <%- include('partials/chess-board') %>
                        <% } else if (currentGame.id === 'connect4') { %>
                            <!-- Connect 4 Board -->
                            <%- include('partials/connect4-board') %>
                        <% } else if (currentGame.id === 'dots-and-boxes') { %>
                            <!-- Dots and Boxes Board -->
                            <%- include('partials/dots-and-boxes-board') %>
                        <% } else { %>
                            <!-- Placeholder for other games -->
                            <div class="text-center">
                                <div class="text-6xl mb-4"><%= currentGame.icon %></div>
                                <h3 class="text-xl font-bold mb-2">Coming Soon!</h3>
                                <p class="opacity-70 mb-4"><%= currentGame.name %> is currently in development.</p>
                                <a href="/games" class="btn btn-primary">Browse Other Games</a>
                            </div>
                        <% } %>
                    </div>

                    <!-- Game Status - Fixed at bottom -->
                    <div class="text-center mt-4 flex-shrink-0">
                        <div id="game-status" class="text-lg font-semibold mb-2">
                            <% if (currentGame.id === 'tic-tac-toe') { %>
                                Your turn! Choose a square.
                            <% } else if (currentGame.id === 'chess') { %>
                                Choose your color to start playing!
                            <% } else if (currentGame.id === 'connect4') { %>
                                Your turn! Choose a column to drop your red piece.
                            <% } else if (currentGame.id === 'dots-and-boxes') { %>
                                Your turn! Click on any line to start.
                            <% } else { %>
                                Game will start when available.
                            <% } %>
                        </div>
                        <div id="game-info" class="text-sm opacity-70">
                            <% if (currentGame.id === 'tic-tac-toe') { %>
                                Make your first move.
                            <% } else if (currentGame.id === 'chess') { %>
                                Click a piece to see valid moves.
                            <% } else if (currentGame.id === 'connect4') { %>
                                Drop pieces to connect four in a row!
                            <% } else if (currentGame.id === 'dots-and-boxes') { %>
                                Complete boxes by drawing their fourth side.
                            <% } else { %>
                                AI analysis will be available when the game launches.
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Game Info Panel - Scrollable if needed -->
        <div class="w-full lg:w-80 overflow-y-auto">
            <!-- AI Thoughts / Game Status -->
            <div class="card bg-base-200 shadow-lg mb-4">
                <div class="card-body">
                    <h3 class="card-title text-base">
                        <% if (currentGame.id === 'chess') { %>
                            <span class="text-lg">♟️ Game Status</span>
                        <% } else { %>
                            <span class="text-lg">🤖 AI Thoughts</span>
                        <% } %>
                    </h3>
                    <!-- Fixed height content area to prevent bouncing -->
                    <div id="ai-thoughts" class="h-20 flex items-start mt-2">
                        <div class="text-sm opacity-70">
                            <% if (currentGame.id === 'tic-tac-toe') { %>
                                Ready for a new game! Make your first move.
                            <% } else if (currentGame.id === 'chess') { %>
                                Select your color and start practicing!
                            <% } else if (currentGame.id === 'connect4') { %>
                                Ready to play Connect 4! Drop your red piece in any column.
                            <% } else if (currentGame.id === 'dots-and-boxes') { %>
                                Ready to play! Click on any line to draw it.
                            <% } else { %>
                                This game is currently in development. Stay tuned for AI-powered gameplay!
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Game Statistics -->
            <div class="card bg-base-200 shadow-lg mb-4">
                <div class="card-body">
                    <h3 class="card-title text-base">📊 Game Stats</h3>
                    <!-- Fixed height content area -->
                    <div class="h-16 mt-2">
                        <div class="space-y-2">
                            <div class="flex justify-between text-sm">
                                <span>Games Played:</span>
                                <span id="games-played">0</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span>Wins:</span>
                                <span id="wins">0</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span>Win Rate:</span>
                                <span id="win-rate">0%</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Game Tips -->
            <div class="card bg-base-200 shadow-lg mb-4">
                <div class="card-body">
                    <h3 class="card-title text-base">💡 Pro Tips</h3>
                    <!-- Fixed height content area -->
                    <div class="h-20 mt-2">
                        <div class="text-sm opacity-80 space-y-1">
                            <% if (currentGame.id === 'tic-tac-toe') { %>
                                <p>• Control the center square early</p>
                                <p>• Watch for two-in-a-row opportunities</p>
                                <p>• Block your opponent's winning moves</p>
                            <% } else if (currentGame.id === 'chess') { %>
                                <p>• Control the center of the board</p>
                                <p>• Develop your pieces early</p>
                                <p>• Castle early to protect your king</p>
                            <% } else if (currentGame.id === 'connect4') { %>
                                <p>• Control the center columns</p>
                                <p>• Look for diagonal opportunities</p>
                                <p>• Set up multiple threat options</p>
                            <% } else if (currentGame.id === 'dots-and-boxes') { %>
                                <p>• Avoid giving away boxes to your opponent</p>
                                <p>• Count the chains to plan ahead</p>
                                <p>• Force your opponent into bad positions</p>
                            <% } else { %>
                                <p>• Tips will be available when the game launches</p>
                                <p>• Stay tuned for AI-powered strategies</p>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Score Display (for supported games) -->
            <% if (currentGame.id === 'tic-tac-toe' || currentGame.id === 'connect4' || currentGame.id === 'dots-and-boxes') { %>
                <div class="card bg-base-200 shadow-lg">
                    <div class="card-body">
                        <h3 class="card-title text-base">🏆 Score</h3>
                        <!-- Fixed height content area -->
                        <div class="h-16 flex items-center justify-center mt-2">
                            <div class="flex justify-between items-center w-full">
                                <div class="text-center">
                                    <div class="text-2xl font-bold text-primary" id="player-score">0</div>
                                    <div class="text-sm opacity-70">You</div>
                                </div>
                                <div class="text-center">
                                    <div class="text-lg opacity-50">VS</div>
                                </div>
                                <div class="text-center">
                                    <div class="text-2xl font-bold text-secondary" id="ai-score">0</div>
                                    <div class="text-sm opacity-70">AI</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</div>

<!-- Game-specific Rules Modal -->
<div id="rules-modal" class="modal">
    <div class="modal-box">
        <h3 class="font-bold text-lg mb-4">How to Play <%= currentGame.name %></h3>
        <div class="space-y-4 overflow-y-auto">
            <% if (currentGame.id === 'tic-tac-toe') { %>
                <p>🎯 <strong>Objective:</strong> Get three X's in a row (horizontal, vertical, or diagonal)</p>
                <p>🎮 <strong>Your Turn:</strong> Click any empty square to place your X</p>
                <p>🤖 <strong>AI Turn:</strong> The AI will automatically place its O</p>
                <p>🏆 <strong>Winning:</strong> First to get three in a row wins!</p>
                <p>🔄 <strong>Draw:</strong> If the board fills up with no winner, it's a tie</p>
            <% } else if (currentGame.id === 'chess') { %>
                <p>♔ <strong>Objective:</strong> Practice chess moves and strategy</p>
                <p>🎮 <strong>Play Style:</strong> Choose to play as White or Black</p>
                <p>⚡ <strong>Practice Mode:</strong> Make moves for both sides to explore positions</p>
                <p>🔄 <strong>Board Flip:</strong> Board automatically orients so you play from the bottom</p>
                <p>📝 <strong>Move History:</strong> Track all moves in standard chess notation</p>
            <% } else if (currentGame.id === 'connect4') { %>
                <p>🎯 <strong>Objective:</strong> Connect four of your pieces in a row (horizontal, vertical, or diagonal)</p>
                <p>🎮 <strong>How to Play:</strong> Click on any column to drop your red piece</p>
                <p>🤖 <strong>AI Turn:</strong> The AI will drop its yellow piece</p>
                <p>🏆 <strong>Winning:</strong> First to connect four pieces wins!</p>
                <p>🔄 <strong>Strategy:</strong> Block your opponent while building your own connections</p>
            <% } else if (currentGame.id === 'dots-and-boxes') { %>
                <p>🎯 <strong>Objective:</strong> Complete more boxes than your opponent</p>
                <p>🎮 <strong>How to Play:</strong> Click on dotted lines to draw them</p>
                <p>📦 <strong>Completing Boxes:</strong> Draw the fourth side of a box to claim it and get another turn</p>
                <p>🏆 <strong>Winning:</strong> Player with the most completed boxes wins!</p>
                <p>🧠 <strong>Strategy:</strong> Avoid giving away boxes by not drawing the third side</p>
            <% } else { %>
                <p>📋 Rules for <%= currentGame.name %> will be available when the game launches.</p>
                <p>🚀 This game is currently in development and will be available soon!</p>
            <% } %>
        </div>
        <div class="modal-action">
            <button class="btn" onclick="closeModal('rules-modal')">Got it!</button>
        </div>
    </div>
    <div class="modal-backdrop" onclick="closeModal('rules-modal')"></div>
</div>

<%# Include game-specific JavaScript %>
<% if (currentGame.id === 'tic-tac-toe') { %>
    <script>
        var pageScripts = ['tic-tac-toe.js'];
    </script>
<% } else if (currentGame.id === 'chess') { %>
    <script>
        var pageScripts = ['chess.js'];
    </script>
<% } else if (currentGame.id === 'connect4') { %>
    <script>
        var pageScripts = ['connect4.js'];
    </script>
<% } else if (currentGame.id === 'dots-and-boxes') { %>
    <script>
        var pageScripts = ['dots-and-boxes.js'];
    </script>
<% } %>