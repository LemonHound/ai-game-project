<!-- Game Header -->
<div class="mb-6">
    <div class="breadcrumbs text-sm mb-4">
        <ul>
            <li><a href="/" class="link">Home</a></li>
            <li><a href="/games" class="link">Games</a></li>
            <li class="opacity-70"><%= currentGame.name %></li>
        </ul>
    </div>

    <div class="flex flex-col lg:flex-row lg:items-center gap-4 mb-6">
        <div class="flex items-center gap-4">
            <div class="w-16 h-16 bg-gradient-to-br from-accent to-secondary rounded-xl flex items-center justify-center">
                <span class="text-3xl"><%= currentGame.icon %></span>
            </div>
            <div>
                <h1 class="text-3xl font-bold"><%= currentGame.name %></h1>
                <p class="text-base-content opacity-70"><%= currentGame.description %></p>
            </div>
        </div>

        <div class="flex gap-2 lg:ml-auto">
            <button class="btn btn-primary" onclick="startGame()">
                <span class="mr-2">🎮</span>
                New Game
            </button>
            <button class="btn btn-outline" onclick="openModal('rules-modal')">
                <span class="mr-2">❓</span>
                Rules
            </button>
        </div>
    </div>
</div>

<!-- Game Stats -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
    <div class="stat bg-base-200 rounded-lg">
        <div class="stat-title">Games Played</div>
        <div class="stat-value text-primary"><%= gameStats.gamesPlayed %></div>
        <div class="stat-desc">Total matches</div>
    </div>
    <div class="stat bg-base-200 rounded-lg">
        <div class="stat-title">Win Rate</div>
        <div class="stat-value text-secondary"><%= gameStats.winRate %>%</div>
        <div class="stat-desc">Against AI</div>
    </div>
    <div class="stat bg-base-200 rounded-lg">
        <div class="stat-title">Best Streak</div>
        <div class="stat-value text-accent"><%= gameStats.bestStreak %></div>
        <div class="stat-desc">Consecutive wins</div>
    </div>
    <div class="stat bg-base-200 rounded-lg">
        <div class="stat-title">AI Level</div>
        <div class="stat-value text-success"><%= gameStats.aiLevel %></div>
        <div class="stat-desc">Adaptive difficulty</div>
    </div>
</div>

<!-- Game Board Container -->
<div class="flex flex-col lg:flex-row gap-6">
    <!-- Game Board -->
    <div class="flex-1">
        <div class="card bg-base-200 shadow-xl">
            <div class="card-body">
                <h2 class="card-title mb-4">Game Board</h2>

                <!-- Game-specific content will be inserted here -->
                <% if (currentGame.id === 'tic-tac-toe') { %>
                    <!-- Tic Tac Toe Board -->
                    <div id="game-board" class="grid grid-cols-3 gap-2 max-w-md mx-auto">
                        <!-- Board squares will be generated by JavaScript -->
                    </div>
                <% } else { %>
                    <!-- Placeholder for other games -->
                    <div class="text-center py-12">
                        <div class="text-6xl mb-4"><%= currentGame.icon %></div>
                        <h3 class="text-xl font-bold mb-2">Coming Soon!</h3>
                        <p class="opacity-70"><%= currentGame.name %> is currently in development.</p>
                        <a href="/games" class="btn btn-primary mt-4">Browse Other Games</a>
                    </div>
                <% } %>

                <!-- Game Status -->
                <div class="text-center mt-6">
                    <div id="game-status" class="text-lg font-semibold mb-4">
                        <% if (currentGame.id === 'tic-tac-toe') { %>
                            Your turn! Choose a square.
                        <% } else { %>
                            Game will start when available.
                        <% } %>
                    </div>
                    <% if (currentGame.id === 'tic-tac-toe') { %>
                        <div class="flex justify-center gap-2">
                            <button class="btn btn-outline btn-sm" onclick="restartGame()">Restart</button>
                            <button class="btn btn-outline btn-sm" onclick="getHint()">Hint</button>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Game Info Sidebar -->
    <div class="lg:w-80">
        <div class="space-y-6">
            <!-- Current Player -->
            <div class="card bg-base-200 shadow-lg">
                <div class="card-body">
                    <h3 class="card-title text-base">Current Player</h3>
                    <div class="flex items-center gap-3 mt-2">
                        <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center">
                            <span class="text-primary-content font-bold">X</span>
                        </div>
                        <span>Your Turn</span>
                    </div>
                </div>
            </div>

            <!-- AI Thoughts -->
            <div class="card bg-base-200 shadow-lg">
                <div class="card-body">
                    <h3 class="card-title text-base">AI Analysis</h3>
                    <div id="ai-thoughts" class="text-sm mt-2 opacity-70">
                        <% if (currentGame.id === 'tic-tac-toe') { %>
                            Ready for a new game! Make your first move.
                        <% } else { %>
                            AI analysis will be available when the game launches.
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Move History -->
            <div class="card bg-base-200 shadow-lg">
                <div class="card-body">
                    <h3 class="card-title text-base">Move History</h3>
                    <div id="move-history" class="space-y-1 mt-2 max-h-48 overflow-y-auto">
                        <div class="text-sm opacity-70">No moves yet</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Game-specific Rules Modal -->
<div id="rules-modal" class="modal">
    <div class="modal-box">
        <h3 class="font-bold text-lg mb-4">How to Play <%= currentGame.name %></h3>
        <div class="space-y-4">
            <% if (currentGame.id === 'tic-tac-toe') { %>
                <p>🎯 <strong>Objective:</strong> Get three X's in a row (horizontal, vertical, or diagonal)</p>
                <p>🎮 <strong>Your Turn:</strong> Click any empty square to place your X</p>
                <p>🤖 <strong>AI Turn:</strong> The AI will automatically place its O</p>
                <p>🏆 <strong>Winning:</strong> First to get three in a row wins!</p>
                <p>🔄 <strong>Draw:</strong> If the board fills up with no winner, it's a tie</p>
            <% } else { %>
                <p>📋 Rules for <%= currentGame.name %> will be available when the game launches.</p>
                <p>🚀 This game is currently in development and will be available soon!</p>
            <% } %>
        </div>
        <div class="modal-action">
            <button class="btn" onclick="closeModal('rules-modal')">Got it!</button>
        </div>
    </div>
    <div class="modal-backdrop" onclick="closeModal('rules-modal')"></div>
</div>

<%# Include game-specific JavaScript %>
<% if (currentGame.id === 'tic-tac-toe') { %>
    <script>
        // Set pageScripts for the layout
        var pageScripts = ['tic-tac-toe.js'];
    </script>
    <script src="/js/tic-tac-toe.js"></script>
<% } %>