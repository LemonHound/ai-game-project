<div class="h-full overflow-hidden flex flex-col p-4 lg:p-6">
    <!-- Scrollable Content Area -->
    <div class="flex-1 overflow-y-auto games-scroll pr-2">

        <!-- Fixed Header Section -->
        <div class="flex-shrink-0 mb-8">
            <!-- Page Header -->
            <div class="text-center">
                <h1 class="text-4xl font-bold mb-4">🎮 All Games</h1>
                <p class="text-lg opacity-70 max-w-2xl mx-auto">
                    Explore our collection of AI-powered games. Each game features adaptive AI that learns from your playing style.
                </p>
            </div>
        </div>

        <!-- Featured Games Grid -->
        <section class="mb-12">
            <h2 class="text-2xl font-bold mb-6">🌟 Featured Games</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="featured-games">
                <% allGames.forEach(game => { %>
                    <div class="card bg-base-200 shadow-xl hover:shadow-2xl transition-all duration-300 card-game-link <%= highlight === game.id ? 'ring-2 ring-primary' : '' %>"
                         data-category="<%= game.category %>"
                         data-status="<%= game.status %>">
                        <figure class="px-6 pt-6">
                            <div class="w-full h-32 bg-gradient-to-br from-accent to-secondary rounded-lg flex items-center justify-center">
                                <span class="text-5xl"><%= game.icon %></span>
                            </div>
                        </figure>
                        <div class="card-body">
                            <h3 class="card-title">
                                <%= game.name %>
                                <div class="badge badge-<%= game.difficulty === 'Easy' ? 'primary' : game.difficulty === 'Medium' ? 'secondary' : game.difficulty === 'Hard' ? 'accent' : 'neutral' %>">
                                    <%= game.difficulty %>
                                </div>
                            </h3>
                            <p class="opacity-70 text-sm"><%= game.description %></p>

                            <!-- Game Stats -->
                            <div class="flex justify-between text-xs opacity-60 mt-2">
                                <span>🎯 <%= game.category %></span>
                                <span>⚡ <%= game.status %></span>
                            </div>

                            <div class="card-actions justify-end mt-4">
                                <% if (game.status === 'active') { %>
                                    <a href="/game/<%= game.id %>" class="btn btn-primary btn-sm">
                                        Play Now
                                    </a>
                                <% } else if (game.status === 'beta') { %>
                                    <a href="/game/<%= game.id %>" class="btn btn-secondary btn-sm">
                                        Try Beta
                                    </a>
                                <% } else { %>
                                    <button class="btn btn-disabled btn-sm" disabled>
                                        Coming Soon
                                    </button>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        </section>

        <!-- Game Statistics -->
        <section class="mb-8">
            <h2 class="text-2xl font-bold mb-6">📊 Game Statistics</h2>
            <div class="stats stats-horizontal shadow-lg bg-base-200 w-full">
                <div class="stat">
                    <div class="stat-figure text-primary">
                        <span class="text-3xl">🎮</span>
                    </div>
                    <div class="stat-title">Total Games</div>
                    <div class="stat-value text-primary"><%= allGames.length %></div>
                    <div class="stat-desc">Available to play</div>
                </div>

                <div class="stat">
                    <div class="stat-figure text-secondary">
                        <span class="text-3xl">⚡</span>
                    </div>
                    <div class="stat-title">Active Games</div>
                    <div class="stat-value text-secondary"><%= allGames.filter(g => g.status === 'active').length %></div>
                    <div class="stat-desc">Ready to play</div>
                </div>

                <div class="stat">
                    <div class="stat-figure text-accent">
                        <span class="text-3xl">🧪</span>
                    </div>
                    <div class="stat-title">Beta Games</div>
                    <div class="stat-value text-accent"><%= allGames.filter(g => g.status === 'beta').length %></div>
                    <div class="stat-desc">In testing</div>
                </div>

                <div class="stat">
                    <div class="stat-figure text-info">
                        <span class="text-3xl">🚀</span>
                    </div>
                    <div class="stat-title">Coming Soon</div>
                    <div class="stat-value text-info"><%= allGames.filter(g => g.status === 'coming-soon').length %></div>
                    <div class="stat-desc">In development</div>
                </div>
            </div>
        </section>
    </div>
</div>