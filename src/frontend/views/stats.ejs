<div class="max-w-4xl mx-auto">
    <div class="text-center mb-8">
        <h1 class="text-4xl font-bold mb-4 bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">
            Player Statistics
        </h1>
        <p class="text-xl opacity-70">
            Check out your gaming progress and achievements
        </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Profile Info Card -->
        <div class="lg:col-span-1">
            <div class="card bg-base-200 shadow-xl">
                <div class="card-body text-center">
                    <div class="avatar mb-4">
                        <div class="w-24 rounded-full">
                            <img src="<%= currentUser.profile_picture || '/images/default-avatar.png' %>"
                                 alt="Profile Picture" />
                        </div>
                    </div>
                    <h2 class="card-title justify-center text-2xl">
                        <%= currentUser.display_name || currentUser.username %>
                    </h2>
                    <p class="text-base-content/70 mb-2">@<%= currentUser.username %></p>
                    <p class="text-sm text-base-content/60"><%= currentUser.email %></p>

                    <div class="divider"></div>

                    <div class="stats stats-vertical shadow">
                        <div class="stat">
                            <div class="stat-title">Member Since</div>
                            <div class="stat-value text-sm">
                                <%= new Date(currentUser.created_at).toLocaleDateString() %>
                            </div>
                        </div>
                        <div class="stat">
                            <div class="stat-title">Auth Provider</div>
                            <div class="stat-value text-sm capitalize">
                                <%= currentUser.auth_provider %>
                            </div>
                        </div>
                        <div class="stat">
                            <div class="stat-title">Last Login</div>
                            <div class="stat-value text-sm">
                                <%= currentUser.last_login ? new Date(currentUser.last_login).toLocaleDateString() : 'Never' %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Gaming Stats -->
        <div class="lg:col-span-2">
            <div class="card bg-base-200 shadow-xl mb-6">
                <div class="card-body">
                    <h3 class="card-title text-xl mb-4">Gaming Statistics</h3>
                    <div class="stats stats-horizontal shadow w-full">
                        <div class="stat">
                            <div class="stat-figure text-primary">
                                <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                            </div>
                            <div class="stat-title">Games Played</div>
                            <div class="stat-value text-primary">15</div>
                            <div class="stat-desc">↗︎ 3 this week</div>
                        </div>

                        <div class="stat">
                            <div class="stat-figure text-secondary">
                                <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3z"></path>
                                </svg>
                            </div>
                            <div class="stat-title">Win Rate</div>
                            <div class="stat-value text-secondary">67%</div>
                            <div class="stat-desc">↗︎ +5% from last month</div>
                        </div>

                        <div class="stat">
                            <div class="stat-figure text-accent">
                                <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                                </svg>
                            </div>
                            <div class="stat-title">Best Streak</div>
                            <div class="stat-value text-accent">8</div>
                            <div class="stat-desc">Current: 3</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Games -->
            <div class="card bg-base-200 shadow-xl">
                <div class="card-body">
                    <h3 class="card-title text-xl mb-4">Recent Games</h3>
                    <div class="overflow-x-auto">
                        <table class="table table-zebra">
                            <thead>
                            <tr>
                                <th>Game</th>
                                <th>Result</th>
                                <th>Score</th>
                                <th>Date</th>
                            </tr>
                            </thead>
                            <tbody>
                            <tr>
                                <td>
                                    <div class="flex items-center space-x-3">
                                        <span class="text-2xl">⭕</span>
                                        <span>Tic Tac Toe</span>
                                    </div>
                                </td>
                                <td><span class="badge badge-success">Win</span></td>
                                <td>150</td>
                                <td>2 hours ago</td>
                            </tr>
                            <tr>
                                <td>
                                    <div class="flex items-center space-x-3">
                                        <span class="text-2xl">🔴</span>
                                        <span>Connect 4</span>
                                    </div>
                                </td>
                                <td><span class="badge badge-error">Loss</span></td>
                                <td>75</td>
                                <td>1 day ago</td>
                            </tr>
                            <tr>
                                <td>
                                    <div class="flex items-center space-x-3">
                                        <span class="text-2xl">⬜</span>
                                        <span>Dots and Boxes</span>
                                    </div>
                                </td>
                                <td><span class="badge badge-success">Win</span></td>
                                <td>220</td>
                                <td>2 days ago</td>
                            </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>