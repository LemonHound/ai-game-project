<!DOCTYPE html>
<html lang="en" data-theme="abyss">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/output.css">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎮</text></svg>">
    <%- include('partials/head-extras') %>
</head>
<body class="bg-base-100 h-screen overflow-hidden">
<div class="navbar-fixed">
    <%- include('partials/navbar') %>
</div>
<div class="flex h-screen content-below-navbar overflow-hidden">
    <% if (typeof showSidebar === 'undefined' || showSidebar) { %>
        <%- include('partials/sidebar') %>

        <!-- Mobile Menu Button -->
        <div class="lg:hidden fixed top-20 left-4 z-50">
            <button class="btn btn-square btn-primary" onclick="document.getElementById('mobile-sidebar').classList.toggle('hidden')">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
        </div>

        <%- include('partials/mobile-sidebar') %>
    <% } %>

    <!-- Main Content Container -->
    <main class="<%= typeof showSidebar === 'undefined' || showSidebar ? 'flex-1' : 'w-full' %> overflow-hidden flex flex-col">
        <!-- Content Area -->
        <div class="flex-1 overflow-hidden">
            <%- include(currentTemplate) %>
        </div>
    </main>
</div>

<%- include('partials/modals') %>
<%- include('partials/scripts') %>
</body>
</html>